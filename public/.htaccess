Options -Indexes
RewriteEngine On

# Game API — serve directly
RewriteRule ^api/game-score\.php$ api/game-score.php [L]
RewriteRule ^api/game-leaderboard\.php$ api/game-leaderboard.php [L]

# אם mod_rewrite עובד — נתב הכל ל-index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php [QSA,L]

# אם גישה ישירה ל-index.php — נתב ל-/ (נקי)
RewriteCond %{THE_REQUEST} ^GET.*index\.php [NC]
RewriteRule ^index\.php$ / [R=301,L]

# Redirect legacy PHP files
RewriteCond %{THE_REQUEST} ^GET.*includes/lab_dashboard\.php [NC]
RewriteRule ^includes/lab_dashboard\.php$ /lab [R=301,L]
